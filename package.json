{
  "name": "fidelis-catholic-bible",
  "private": true,
  "version": "1.13.3",
  "type": "module",
  "description": "Fidelis — a Catholic Bible app with unaltered public-domain texts: Douay-Rheims, Catholic Public Domain Version, and the Clementine Latin Vulgate.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ogprotege/Fidelis"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint src",
    "test": "tsx scripts/test-liturgical.ts && tsx scripts/test-data.ts && node scripts/build-manifest.mjs --verify && eslint src",
    "golden": "tsx scripts/build-golden.ts",
    "preview": "vite preview",
    "data": "node scripts/build-data.mjs",
    "report": "node scripts/build-report.mjs",
    "quotes": "node scripts/build-quotes.mjs",
    "manifest": "node scripts/build-manifest.mjs",
    "verify-data": "node scripts/build-manifest.mjs --verify",
    "lectionary": "node scripts/build-lectionary.mjs",
    "haydock": "tsx scripts/build-haydock.mjs",
    "catena": "node scripts/build-catena.mjs",
    "trent": "node scripts/build-trent.mjs",
    "commentary": "npm run haydock && npm run catena",
    "votd-widget": "node scripts/build-votd-widget.mjs",
    "calendar-widget": "tsx scripts/build-calendar-widget.ts",
    "widgets": "npm run votd-widget && npm run calendar-widget",
    "ccc": "tsx scripts/build-ccc.mjs && node scripts/build-ccc-urls.mjs && npm run manifest",
    "build-nabre": "node scripts/build-nabre.mjs",
    "build-ccc-text": "node scripts/build-ccc-text.mjs",
    "check-docs": "node scripts/check-doc-links.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "esbuild@0.28.1": true
  }
}
