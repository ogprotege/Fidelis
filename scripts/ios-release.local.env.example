# iOS release credentials --- copy this file to scripts/ios-release.local.env
# (which is gitignored) and fill in your own values. Used by
# scripts/ios-testflight.sh and scripts/asc-build-status.mjs.
#
# Generate an App Store Connect API key (one time):
#   App Store Connect -> Users and Access -> Integrations -> App Store Connect API
#   -> generate a key with Admin access -> download the .p8 (only downloadable once).
#
# TEAM_ID:        your 10-char Apple Developer Team ID (Developer portal -> Membership).
# ASC_KEY_ID:     the 10-char Key ID shown next to the key.
# ASC_ISSUER_ID:  the Issuer ID (a UUID) shown at the top of the Keys page.
# ASC_KEY_PATH:   absolute path to the downloaded AuthKey_<KEYID>.p8 file.

TEAM_ID=XXXXXXXXXX
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=/Users/you/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
