<?xml version="1.0" encoding="utf-8"?>
<!-- Today at Mass widget — the gold cross + label, the liturgical day in serif,
     the Mass-reading citations beneath. Same day-theme surface as the app. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cal_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_marginEnd="5dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_cross_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:text="@string/widget_calendar_label"
            android:textColor="@color/fidelis_gold"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/cal_day"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="serif"
        android:maxLines="2"
        android:textColor="@color/fidelis_ink"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/cal_readings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="5dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="serif"
        android:lineSpacingMultiplier="1.1"
        android:maxLines="6"
        android:textColor="@color/fidelis_muted"
        android:textSize="12sp" />
</LinearLayout>
